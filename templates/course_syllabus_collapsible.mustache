{{!
  @template local_envasyllabus/course_syllabus_collapsible

  Syllabus templated

  The purpose of this template is to output the syllabus of a course

  Classes required for JS:

  Data attributes required for JS:

  Context variables required for this template:

  Example context (json):
  {
    "id": "teachers-5c6b6b6b6b6b6b6b6b6b6b6b6b6b6b6b",
    "type": "teachers",
    "title": "Teachers",
    "content": ""
  }

}}
<div class="course-syllabus-collapsible">
    <h3 class="syllabus-title headline-v2 p-1 px-2" data-toggle="collapse" data-target="#{{$id}}{{/id}}" aria-expanded="true" aria-controls="{{$id}}{{/id}}">
        <span class="title-caret mr-3"></span><span>{{$title}}{{/title}}</span>
    </h3>
    <div class="container-fluid syllabus-desc-container {{$type}}{{/type}}-container" id="{{$id}}{{/id}}">
        <div class="d-flex flex-wrap align-content-around">
            {{$content}}{{/content}}
        </div>
    </div>
</div>